@startuml
title Global Class Diagram

skinparam classAttributeIconSize 0
hide methods

class "main.cpp" as Main {
  - Inicia aplicacao
  - Menus
}

class View {
  - Recolhe inputs
  - Mostra resultados
}

class Controller {
  - Coordena UC
  - Chama services
}

class DTO {
  - Transporta dados
  - View -> Service
}

class Service {
  - Regras de negocio
  - Usa repository
  - Usa containers
}

class Repository {
  - GymRepositoryMemory
  - Guarda model em memoria
}

class Mappers {
  - DTO -> Model
  - Model -> DTO
}

class Exceptions {
  - InvalidDataException
  - NoDataException
  - DuplicatedDataException
}

class Containers {
  - AthleteContainer
  - InstructorContainer
  - ModalityContainer
  - RoomContainer
  - Outros
}

class Model {
  - Gym
  - User
  - Athlete
  - Instructor
  - Modality
  - Room
  - ClassSession
}

Main --> View : uses
Main --> Service : uses
Main --> Mappers : uses

View --> Controller : uses
Controller --> DTO : passes
Controller --> Service : calls

Service --> DTO : creates DTO
Service --> Repository : uses
Service --> Mappers : maps
Service --> Exceptions : throws
Service --> Containers : manipulates

Repository --> Model : returns
Containers --> Model : has

@enduml